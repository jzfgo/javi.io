---
import Head from "@components/Head.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import { AUTHOR } from "@consts";

type Props = {
  title: string;
  description: string;
  image?: string;
  alternateUrls?: { es: string; en: string };
};

const { title, description, image, alternateUrls } = Astro.props;
const pageTitle = title.startsWith(AUTHOR.NAME) ? title : `${title} | ${AUTHOR.NAME}`;
---

<!doctype html>
<html lang={Astro.currentLocale ?? "es"}>
  <head>
    <Head title={pageTitle} description={description} image={image} alternateUrls={alternateUrls} />
  </head>
  <body>
    <!-- Google Tag Manager (noscript) -->
    <noscript>
      <iframe src="https://www.googletagmanager.com/ns.html?id=GTM-N7RN8K79"
        height="0" width="0" style="display:none;visibility:hidden"></iframe>
    </noscript>
    <!-- End Google Tag Manager (noscript) -->
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
