---
import PageLayout from "@layouts/PageLayout.astro";
import Container from "@components/Container.astro";
import Link from "@components/Link.astro";
import { SITE, AUTHOR, SOCIALS } from "@consts";
---

<PageLayout title="About" description={AUTHOR.BIO}>
  <Container>
    <div class="space-y-10">
      <div class="animate flex items-center gap-6">
        <img
          src={AUTHOR.AVATAR}
          alt={AUTHOR.NAME}
          class="w-20 h-20 rounded-full object-cover"
        />
        <div>
          <h1 class="text-xl font-semibold text-black dark:text-white">{AUTHOR.NAME}</h1>
        </div>
      </div>
      <div class="animate">
        <p>{AUTHOR.BIO}</p>
      </div>
      <div class="animate space-y-2">
        <h2 class="font-semibold text-black dark:text-white">Contacto</h2>
        <ul class="flex flex-wrap gap-2">
          {SOCIALS.map(SOCIAL => (
            <li class="flex gap-x-2 text-nowrap">
              <Link href={SOCIAL.HREF} external aria-label={`${SITE.NAME} on ${SOCIAL.NAME}`}>
                {SOCIAL.NAME}
              </Link>
              {"/"}
            </li>
          ))}
          <li class="line-clamp-1">
            <Link href={`mailto:${SITE.EMAIL}`} aria-label={`Email ${SITE.NAME}`}>
              {SITE.EMAIL}
            </Link>
          </li>
        </ul>
      </div>
    </div>
  </Container>
</PageLayout>
