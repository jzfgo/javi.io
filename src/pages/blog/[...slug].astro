---
import { type CollectionEntry, getCollection, render } from "astro:content";
import PageLayout from "@layouts/PageLayout.astro";
import Container from "@components/Container.astro";
import FormattedDate from "@components/FormattedDate.astro";
import { readingTime, idToSlug } from "@lib/utils";
import BackToPrev from "@components/BackToPrev.astro";

export async function getStaticPaths() {
  const posts = (await getCollection("blog-es"))
    .filter(post => !post.data.draft)
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
  return posts.map((post) => ({
    params: { slug: idToSlug(post.id) },
    props: post,
  }));
}
type Props = CollectionEntry<"blog-es">;

const post = Astro.props;
const { Content } = await render(post);

const enPosts = await getCollection("blog-en", ({ data }) => !data.draft);
const translation = post.data.translationKey
  ? enPosts.find(p => p.data.translationKey === post.data.translationKey)
  : enPosts.find(p => idToSlug(p.id) === idToSlug(post.id));

const siteBase = (Astro.site?.href ?? "https://javi.io/").replace(/\/$/, "");
const alternateUrls = {
  es: `${siteBase}/blog/${idToSlug(post.id)}`,
  en: translation ? `${siteBase}/en/blog/${idToSlug(translation.id)}` : `${siteBase}/en/blog`,
};
---

<PageLayout title={post.data.title} description={post.data.description} image={post.data.hero?.src} alternateUrls={alternateUrls}>
  <Container>
    <div class="animate">
      <BackToPrev href="/blog">
        Volver al blog
      </BackToPrev>
    </div>
    {translation && (
      <div class="animate text-sm mt-4 opacity-75">
        <a href={`/en/blog/${idToSlug(translation.id)}`}>Read in English →</a>
      </div>
    )}
    {post.data.hero && (
      <div class="animate my-10">
        <img
          src={post.data.hero?.src}
          alt={post.data.title}
          class="w-full rounded-lg object-cover max-h-96"
        />
      </div>
    )}
    <div class="space-y-1 my-10">
      <div class="animate flex items-center gap-1.5">
        <div class="font-base text-sm">
          <FormattedDate date={post.data.date} />
        </div>
        &bull;
        <div class="font-base text-sm">
          {readingTime(post.body ?? "")} min de lectura
        </div>
      </div>
      <div class="animate text-2xl font-semibold text-black dark:text-white">
        {post.data.title}
      </div>
    </div>
    <article class="animate">
      <Content />
    </article>
  </Container>
</PageLayout>
