---
import PageLayout from "@layouts/PageLayout.astro";
import Container from "@components/Container.astro";
---

<PageLayout title="404" description="Page not found">
  <Container>
    <div class="animate space-y-4">
      <h1 class="text-4xl font-semibold text-black dark:text-white">404</h1>
      <p>Página no encontrada / Page not found.</p>
      <div class="flex gap-4">
        <a href="/" class="underline">← Inicio</a>
        <a href="/en/" class="underline">← Home</a>
      </div>
    </div>
  </Container>
</PageLayout>
