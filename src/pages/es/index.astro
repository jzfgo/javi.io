---
import { getCollection } from "astro:content";
import Container from "@components/Container.astro";
import PageLayout from "@layouts/PageLayout.astro";
import ArrowCard from "@components/ArrowCard.astro";
import Link from "@components/Link.astro";
import { SITE, HOME_ES as HOME, AUTHOR } from "@consts";
import { getIconMap, idToSlug } from "@lib/utils";

const blog = (await getCollection("blog-es"))
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, SITE.NUM_POSTS_ON_HOMEPAGE);

const work = (await getCollection("work-es"))
  .sort((a, b) => b.data.dateStart.valueOf() - a.data.dateStart.valueOf())
  .slice(0, SITE.NUM_WORKS_ON_HOMEPAGE);

const projects = (await getCollection("projects-es"))
  .filter(project => !project.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, SITE.NUM_PROJECTS_ON_HOMEPAGE);

const blogIcons = getIconMap(import.meta.glob("/src/assets/blog/*/icon.*", { eager: true }));
const workIcons = getIconMap(import.meta.glob("/src/assets/work/*/icon.*", { eager: true }));
const projectIcons = getIconMap(import.meta.glob("/src/assets/projects/*/icon.*", { eager: true }));
---

<PageLayout title={HOME.TITLE} description={HOME.DESCRIPTION}>
  <Container>
    <div class="space-y-16">
      <section>
        <article class="space-y-4">
          <h1 class="animate text-3xl font-semibold text-black dark:text-white">
            {HOME.DESCRIPTION}
          </h1>
          <p class="animate">
            {AUTHOR.BIO_ES}
          </p>
        </article>
      </section>

      <section class="animate space-y-6">
        <div class="flex flex-wrap gap-y-2 items-center justify-between">
          <h5 class="font-semibold text-black dark:text-white">
            Últimas entradas
          </h5>
          <Link href="/es/blog">
            Ver todas
          </Link>
        </div>
        <ul class="flex flex-col gap-4">
          {blog.map(post => (
            <li>
              <ArrowCard entry={post} href={`/es/blog/${idToSlug(post.id)}`} icon={blogIcons[post.data.assetSlug ?? idToSlug(post.id)]} />
            </li>
          ))}
        </ul>
      </section>

      <section class="animate space-y-6">
        <div class="flex flex-wrap gap-y-2 items-center justify-between">
          <h5 class="font-semibold text-black dark:text-white">
            Experiencia
          </h5>
          <Link href="/es/work">
            Ver todo
          </Link>
        </div>
        <ul class="flex flex-col gap-4">
          {work.map(entry => (
            <li>
              <ArrowCard entry={entry} href={`/es/work#${idToSlug(entry.id)}`} icon={workIcons[idToSlug(entry.id)]} />
            </li>
          ))}
        </ul>
      </section>

      <section class="animate space-y-6">
        <div class="flex flex-wrap gap-y-2 items-center justify-between">
          <h5 class="font-semibold text-black dark:text-white">
            Proyectos
          </h5>
          <Link href="/es/projects">
            Ver todos
          </Link>
        </div>
        <ul class="flex flex-col gap-4">
          {projects.map(project => (
            <li>
              <ArrowCard entry={project} href={`/es/projects/${idToSlug(project.id)}`} icon={projectIcons[idToSlug(project.id)]} />
            </li>
          ))}
        </ul>
      </section>
    </div>
  </Container>
</PageLayout>
