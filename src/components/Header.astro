---
import Container from "@components/Container.astro";
import Link from "@components/Link.astro";
import Logo from "@components/Logo.astro";
import { SITE } from "@consts";
import { getCollection } from "astro:content";
import { idToSlug } from "@lib/utils";

const locale = Astro.currentLocale ?? "es";
const otherLocale = locale === "es" ? "en" : "es";

// With prefixDefaultLocale: false, ES lives at root, EN at /en
const prefix = (loc: string) => loc === "es" ? "" : "/en";

const pathname = Astro.url.pathname;
// Normalize pathname to ES-equivalent (strip /en prefix), preserve trailing slash
const basePath = locale === "en"
  ? pathname.replace(/^\/en(\/|$)/, "/")
  : pathname;
// Strip trailing slash only for regex slug matching (avoids capturing it as part of the slug)
const cleanPath = basePath.replace(/\/$/, "");

const blogDetailMatch = cleanPath.match(/^\/blog\/(.+)$/);
const projectDetailMatch = cleanPath.match(/^\/projects\/(.+)$/);

let altPath = `${prefix(otherLocale)}/`;

if (blogDetailMatch) {
  const slug = blogDetailMatch[1];
  const currentPost = (await getCollection(`blog-${locale}` as "blog-en" | "blog-es"))
    .find(p => idToSlug(p.id) === slug);
  altPath = `${prefix(otherLocale)}/blog`;
  if (currentPost?.data.translationKey) {
    const translation = (await getCollection(`blog-${otherLocale}` as "blog-en" | "blog-es"))
      .find(p => p.data.translationKey === currentPost.data.translationKey);
    if (translation) altPath = `${prefix(otherLocale)}/blog/${idToSlug(translation.id)}`;
  }
} else if (projectDetailMatch) {
  const slug = projectDetailMatch[1];
  const currentProject = (await getCollection(`projects-${locale}` as "projects-en" | "projects-es"))
    .find(p => idToSlug(p.id) === slug);
  const translation = currentProject
    ? (await getCollection(`projects-${otherLocale}` as "projects-en" | "projects-es"))
        .find(p => currentProject.data.translationKey
          ? p.data.translationKey === currentProject.data.translationKey
          : idToSlug(p.id) === slug)
    : undefined;
  altPath = translation
    ? `${prefix(otherLocale)}/projects/${idToSlug(translation.id)}`
    : `${prefix(otherLocale)}/projects`;
} else {
  altPath = `${prefix(otherLocale)}${basePath}`;
}

const nav = locale === "es"
  ? { blog: "blog", work: "experiencia", projects: "proyectos" }
  : { blog: "blog", work: "work", projects: "projects" };
---

<header>
  <Container>
    <div class="flex flex-wrap gap-y-2 justify-between">
      <Link href={`${prefix(locale)}/`} underline={false} aria-label={SITE.NAME}>
        <Logo />
      </Link>
      <nav class="flex gap-1 items-center">
        <Link href={`${prefix(locale)}/blog`}>
          {nav.blog}
        </Link>
        <span>{`/`}</span>
        <Link href={`${prefix(locale)}/work`}>
          {nav.work}
        </Link>
        <span>{`/`}</span>
        <Link href={`${prefix(locale)}/projects`}>
          {nav.projects}
        </Link>
        <span>{`/`}</span>
        <Link href={altPath} aria-label={`Switch to ${otherLocale.toUpperCase()}`}>
          {otherLocale.toUpperCase()}
        </Link>
      </nav>
    </div>
  </Container>
</header>
