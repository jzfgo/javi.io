---
import Container from "@components/Container.astro";
import Link from "@components/Link.astro";
import Logo from "@components/Logo.astro";
import { SITE } from "@consts";

const locale = Astro.currentLocale ?? "es";
const otherLocale = locale === "es" ? "en" : "es";
const altPath = Astro.url.pathname.startsWith(`/${locale}`)
  ? Astro.url.pathname.replace(`/${locale}`, `/${otherLocale}`)
  : `/${otherLocale}/`;

const nav = locale === "es"
  ? { blog: "blog", work: "experiencia", projects: "proyectos" }
  : { blog: "blog", work: "work", projects: "projects" };
---

<header>
  <Container>
    <div class="flex flex-wrap gap-y-2 justify-between">
      <Link href={`/${locale}/`} underline={false} aria-label={SITE.NAME}>
        <Logo />
      </Link>
      <nav class="flex gap-1 items-center">
        <Link href={`/${locale}/blog`}>
          {nav.blog}
        </Link>
        <span>{`/`}</span>
        <Link href={`/${locale}/work`}>
          {nav.work}
        </Link>
        <span>{`/`}</span>
        <Link href={`/${locale}/projects`}>
          {nav.projects}
        </Link>
        <span>{`/`}</span>
        <Link href={altPath} aria-label={`Switch to ${otherLocale.toUpperCase()}`}>
          {otherLocale.toUpperCase()}
        </Link>
      </nav>
    </div>
  </Container>
</header>
