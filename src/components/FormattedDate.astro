---
interface Props {
  date: Date;
}

const { date } = Astro.props;
const locale = Astro.currentLocale ?? "es";
---

<time datetime={date.toISOString()}>
  {
    date.toLocaleDateString(locale, {
      month: "short",
      day: "numeric",
      year: "numeric",
      timeZone: "UTC",
    })
  }
</time>
