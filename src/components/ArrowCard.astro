---
import type { CollectionEntry } from "astro:content";

type Props = {
  entry: CollectionEntry<"blog-es" | "blog-en" | "projects-es" | "projects-en" | "work-es" | "work-en">;
  href: string;
  icon?: string;
  iconClass?: string;
  tag?: string;
};

const { entry, href, icon, iconClass, tag } = Astro.props;
const title = "company" in entry.data ? entry.data.company : entry.data.title;
const description = "company" in entry.data ? entry.data.role : entry.data.description;
---

<a href={href} class="relative group flex flex-nowrap gap-4 py-3 px-4 pr-10 rounded-lg border border-black/15 dark:border-white/20 hover:bg-black/5 dark:hover:bg-white/5 hover:text-black dark:hover:text-white transition-colors duration-300 ease-in-out">
  {icon && (
    <img src={icon} alt={`${title} logo`} width="64" height="64" class={`size-16 rounded object-cover shrink-0 self-center${iconClass ? ` ${iconClass}` : ""}`} />
  )}
  <div class="flex flex-col flex-1 min-w-0 justify-center">
    <div class="font-semibold truncate">
      {title}
    </div>
    <div class="text-sm truncate">
      {description}
    </div>
    {tag && <span class="type-label text-xs uppercase tracking-widest text-black/30 dark:text-white/30 mt-0.5">{tag}</span>}
  </div>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 24 24"
    class="absolute top-1/2 right-2 -translate-y-1/2 size-5 stroke-2 fill-none stroke-current">
    <line x1="5" y1="12" x2="19" y2="12" class="translate-x-3 group-hover:translate-x-0 scale-x-0 group-hover:scale-x-100 transition-transform duration-300 ease-in-out" />
    <polyline points="12 5 19 12 12 19" class="-translate-x-1 group-hover:translate-x-0 transition-transform duration-300 ease-in-out" />
  </svg>
</a>
